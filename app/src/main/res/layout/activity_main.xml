<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="44dp"
        android:background="@color/sidebar_bg" android:gravity="center_vertical"
        android:paddingHorizontal="4dp" android:orientation="horizontal">

        <!-- Scrollable left section (shrinks/scrolls when narrow) -->
        <HorizontalScrollView
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center_vertical" android:orientation="horizontal">

                <Spinner android:id="@+id/spinnerAR"
                    android:layout_width="wrap_content" android:layout_height="30dp"
                    android:background="@color/surface0"
                    android:popupBackground="@color/base" android:paddingHorizontal="4dp" />

                <CheckBox android:id="@+id/chkGridMain"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Grid" android:textColor="@color/subtext0" android:textSize="10sp"
                    android:checked="true" android:layout_marginStart="6dp"
                    android:buttonTint="@color/mauve" />

                <CheckBox android:id="@+id/chkPan"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pan" android:textColor="@color/subtext0" android:textSize="10sp"
                    android:layout_marginStart="4dp" android:buttonTint="@color/mauve" />

                <CheckBox android:id="@+id/chkLockCenter"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Lock" android:textColor="@color/subtext0" android:textSize="10sp"
                    android:layout_marginStart="2dp" android:layout_marginEnd="4dp"
                    android:buttonTint="@color/mauve" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Fixed right section: always visible -->
        <ImageButton android:id="@+id/btnSettings"
            android:layout_width="38dp" android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="Settings" app:tint="@color/mauve" android:padding="8dp" />
        <ImageButton android:id="@+id/btnOpen"
            android:layout_width="38dp" android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_upload"
            android:contentDescription="Open" app:tint="@color/blue" android:padding="6dp" />
        <ImageButton android:id="@+id/btnSave"
            android:layout_width="38dp" android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_save"
            android:contentDescription="Save" app:tint="@color/mauve" android:padding="6dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Editor -->
    <com.cropcenter.view.CropEditorView
        android:id="@+id/editorView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Row 1: Mode + Lock axes + Undo/Redo/Clear (consolidated) -->
    <LinearLayout android:id="@+id/pointControlsRow"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:background="@color/sidebar_bg" android:gravity="center_vertical"
        android:paddingHorizontal="4dp" android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton android:id="@+id/btnModeSelect"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Select" android:textSize="11sp" android:textColor="@color/mauve"
            android:minWidth="0dp" android:paddingHorizontal="6dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnModeMove"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Move" android:textSize="11sp" android:textColor="@color/surface2"
            android:minWidth="0dp" android:paddingHorizontal="6dp"
            android:insetTop="0dp" android:insetBottom="0dp" />

        <View android:layout_width="1dp" android:layout_height="16dp"
            android:background="@color/surface1" android:layout_marginHorizontal="3dp" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnLockBoth"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Both" android:textSize="11sp" android:textColor="@color/mauve"
            android:minWidth="0dp" android:paddingHorizontal="5dp"
            android:insetTop="0dp" android:insetBottom="0dp"
            android:visibility="gone" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnLockH"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="H" android:textSize="11sp" android:textColor="@color/surface2"
            android:minWidth="0dp" android:paddingHorizontal="5dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnLockV"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="V" android:textSize="11sp" android:textColor="@color/surface2"
            android:minWidth="0dp" android:paddingHorizontal="5dp"
            android:insetTop="0dp" android:insetBottom="0dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnUndo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Undo" android:textSize="11sp" android:textColor="@color/subtext0"
            android:minWidth="0dp" android:paddingHorizontal="6dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnRedo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Redo" android:textSize="11sp" android:textColor="@color/subtext0"
            android:minWidth="0dp" android:paddingHorizontal="6dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnClearPoints"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Clear" android:textSize="11sp" android:textColor="@color/red"
            android:minWidth="0dp" android:paddingHorizontal="6dp"
            android:insetTop="0dp" android:insetBottom="0dp" />

        <TextView android:id="@+id/btnAutoRotate"
            android:layout_width="wrap_content" android:layout_height="22dp"
            android:text="Auto" android:textSize="11sp" android:textColor="@color/subtext0"
            android:gravity="center" android:paddingHorizontal="8dp"
            android:layout_marginStart="4dp" android:background="@color/surface0"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Row 3: Rotation ruler (scrollable) -->
    <com.cropcenter.view.RotationRulerView
        android:id="@+id/rotationRuler"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/sidebar_bg" />

    <!-- Info bar -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="28dp"
        android:background="@color/mantle" android:gravity="center_vertical"
        android:paddingHorizontal="10dp" android:orientation="horizontal">

        <!-- Order: image formats, original size, cropped size, zoom, rotation -->
        <TextView android:id="@+id/txtImageFormats"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/surface2" android:textSize="10sp"
            android:singleLine="true" android:ellipsize="end" />

        <TextView android:id="@+id/txtImageInfo"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/surface2" android:textSize="10sp"
            android:layout_marginStart="8dp" android:singleLine="true" />

        <TextView android:id="@+id/txtTransformArrow"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="→" android:textColor="@color/overlay0" android:textSize="10sp"
            android:layout_marginStart="6dp" android:singleLine="true"
            android:visibility="gone" />

        <TextView android:id="@+id/txtSidebarCropSize"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/subtext0" android:textSize="10sp"
            android:layout_marginStart="6dp" android:singleLine="true" />

        <TextView android:id="@+id/txtZoomBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/mauve" android:textSize="10sp"
            android:layout_marginStart="8dp" android:visibility="gone"
            android:singleLine="true" />

        <TextView android:id="@+id/txtRotDegrees"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0°" android:textColor="@color/mauve" android:textSize="10sp"
            android:layout_marginStart="8dp" android:singleLine="true" />
    </LinearLayout>

</LinearLayout>

    <!-- Progress overlay for long operations (auto-rotation detection) -->
    <LinearLayout android:id="@+id/progressOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center"
        android:background="#AA000000" android:clickable="true"
        android:focusable="true" android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp" android:layout_height="48dp"
            android:indeterminateTint="@color/mauve" />

        <TextView android:id="@+id/progressText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Detecting horizon…" android:textSize="13sp"
            android:textColor="@color/text" android:layout_marginTop="16dp" />
    </LinearLayout>

</FrameLayout>
