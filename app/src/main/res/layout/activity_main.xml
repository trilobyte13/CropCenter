<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="44dp"
        android:background="@color/sidebar_bg" android:gravity="center_vertical"
        android:paddingHorizontal="6dp" android:orientation="horizontal">

        <Spinner android:id="@+id/spinnerAR"
            android:layout_width="wrap_content" android:layout_height="30dp"
            android:background="@color/surface0"
            android:popupBackground="@color/base" android:paddingHorizontal="4dp" />

        <CheckBox android:id="@+id/chkGridMain"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Grid" android:textColor="@color/subtext0" android:textSize="10sp"
            android:checked="true" android:layout_marginStart="4dp"
            android:buttonTint="@color/mauve" />

        <CheckBox android:id="@+id/chkPixelGridMain"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pixel" android:textColor="@color/subtext0" android:textSize="10sp"
            android:layout_marginStart="2dp" android:buttonTint="@color/mauve" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <ImageButton android:id="@+id/btnOpen"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_upload"
            android:contentDescription="Open" app:tint="@color/blue" android:padding="6dp" />
        <ImageButton android:id="@+id/btnSave"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_save"
            android:contentDescription="Save" app:tint="@color/mauve" android:padding="6dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Editor -->
    <com.cropcenter.view.CropEditorView
        android:id="@+id/editorView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Row 1: Mode + Lock -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="34dp"
        android:background="@color/sidebar_bg" android:gravity="center_vertical"
        android:paddingHorizontal="6dp" android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton android:id="@+id/btnModeMove"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Move" android:textSize="11sp" android:textColor="@color/mauve"
            android:minWidth="0dp" android:paddingHorizontal="8dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnModeSelect"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Select" android:textSize="11sp" android:textColor="@color/surface2"
            android:minWidth="0dp" android:paddingHorizontal="8dp"
            android:insetTop="0dp" android:insetBottom="0dp" />

        <View android:layout_width="1dp" android:layout_height="16dp"
            android:background="@color/surface1" android:layout_marginHorizontal="4dp" />

        <!-- Lock buttons: Both only in Select, H/V in both modes -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btnLockBoth"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Both" android:textSize="11sp" android:textColor="@color/mauve"
            android:minWidth="0dp" android:paddingHorizontal="7dp"
            android:insetTop="0dp" android:insetBottom="0dp"
            android:visibility="gone" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnLockH"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="H" android:textSize="11sp" android:textColor="@color/surface2"
            android:minWidth="0dp" android:paddingHorizontal="7dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnLockV"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="V" android:textSize="11sp" android:textColor="@color/surface2"
            android:minWidth="0dp" android:paddingHorizontal="7dp"
            android:insetTop="0dp" android:insetBottom="0dp" />

        <CheckBox android:id="@+id/chkFreeze"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Freeze" android:textColor="@color/subtext0" android:textSize="10sp"
            android:layout_marginStart="2dp" android:buttonTint="@color/mauve" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
    </LinearLayout>

    <!-- Row 2: Point controls -->
    <LinearLayout android:id="@+id/pointControlsRow"
        android:layout_width="match_parent" android:layout_height="32dp"
        android:background="@color/sidebar_bg" android:gravity="center_vertical"
        android:paddingHorizontal="8dp" android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton android:id="@+id/btnUndo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Undo" android:textSize="11sp" android:textColor="@color/subtext0"
            android:minWidth="0dp" android:paddingHorizontal="10dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnRedo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Redo" android:textSize="11sp" android:textColor="@color/subtext0"
            android:minWidth="0dp" android:paddingHorizontal="10dp"
            android:insetTop="0dp" android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnClearPoints"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:text="Clear" android:textSize="11sp" android:textColor="@color/red"
            android:minWidth="0dp" android:paddingHorizontal="10dp"
            android:insetTop="0dp" android:insetBottom="0dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
    </LinearLayout>

    <!-- Row 3: Rotation ruler (scrollable) -->
    <com.cropcenter.view.RotationRulerView
        android:id="@+id/rotationRuler"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/sidebar_bg" />

    <!-- Info bar -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="28dp"
        android:background="@color/mantle" android:gravity="center_vertical"
        android:paddingHorizontal="10dp" android:orientation="horizontal">

        <TextView android:id="@+id/txtImageInfo"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/surface2" android:textSize="10sp" />

        <TextView android:id="@+id/txtSidebarCropSize"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/subtext0" android:textSize="10sp"
            android:layout_marginStart="10dp" />

        <TextView android:id="@+id/txtRotDegrees"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/mauve" android:textSize="10sp"
            android:layout_marginStart="10dp" android:visibility="gone" />

        <TextView android:id="@+id/txtZoomBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/mauve" android:textSize="10sp"
            android:layout_marginStart="10dp" android:visibility="gone" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
    </LinearLayout>

</LinearLayout>
